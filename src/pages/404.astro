---
import Navbar from '@/components/portfolio/navbar.astro';
import Layout from '@/layouts/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <Navbar />
  <main class="flex min-h-screen flex-col items-center justify-center">
    <div class="relative">
      <div class="bubble h-72 w-72 -left-36 -top-36" />
      <div class="bubble h-48 w-48 -right-24 -bottom-24" />
    </div>
    <div class="relative z-10 text-center">
      <h1 class="text-gradient mb-4 text-8xl font-bold">404</h1>
      <p class="mb-8 text-xl text-muted-foreground">
        Oops! The page you're looking for doesn't exist.
      </p>
      <a
        href="/"
        class="inline-block rounded-lg bg-primary px-8 py-3 font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        Go Home
      </a>
    </div>
  </main>
</Layout>
