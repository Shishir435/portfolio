---
let version = 'v0.1.10';
try {
	const res = await fetch(
		'https://img.shields.io/chrome-web-store/v/bfaoaaogfcgomkjfbmfepbiijmciinjl.json',
	);
	const data = await res.json();
	version = data.value;
} catch (e) {
	console.warn('Failed to fetch Ollama version:', e);
}
---

<a
  href="https://chromewebstore.google.com/detail/ollama-client/bfaoaaogfcgomkjfbmfepbiijmciinjl"
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium transition-colors hover:bg-secondary"
>
  <span>Install Ollama Client</span>
  <span class="rounded-full bg-secondary px-2 py-0.5 text-xs text-muted-foreground">{version}</span>
</a>
